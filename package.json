{
  "name": "running-tracker",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "dotnet run --project backend/RunningTracker.API --urls http://localhost:5000",
    "dev:ui": "wait-on http-get://localhost:5000/api/sessions && npm run dev --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.4"
  }
}
